datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["crack_the_safe"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

model User {
  id             String   @id @default(cuid())
  displayName    String
  walletAddress  String?  @unique
  lastLoginDate  String?
  streakDays     Int      @default(0)
  bluffBalance   Int      @default(0)
  isAdmin        Boolean  @default(false)
  isBanned       Boolean  @default(false)
  referralCode   String?  @unique
  referredBy     String?
  createdAt      DateTime @default(now())

  guesses            Guess[]
  ledgerEntries      GuessLedger[]
  taskCompletions    TaskCompletion[]
  crackedVaults      Vault[]            @relation("CrackedBy")
  tokenTransactions  TokenTransaction[]
  auditLogs          AuditLog[]

  @@schema("crack_the_safe")
}

model Vault {
  id        String   @id @default(cuid())
  codeLength Int      @default(4)
  codeHash  String
  startsAt  DateTime @default(now())
  expiresAt DateTime

  isCracked     Boolean  @default(false)
  crackedByUserId String?
  crackedAt     DateTime?
  crackedBy     User?    @relation("CrackedBy", fields: [crackedByUserId], references: [id])

  guesses Guess[]

  @@schema("crack_the_safe")
}

model Guess {
  id               String   @id @default(cuid())
  vaultId          String
  userId           String
  guess            String
  correctPositions Int
  correctDigits    Int
  feedback         String
  createdAt        DateTime @default(now())

  vault Vault @relation(fields: [vaultId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([vaultId, createdAt])
  @@index([userId, vaultId])
  @@schema("crack_the_safe")
}

model GuessLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  taskId    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@schema("crack_the_safe")
}

model Task {
  id           String @id
  name         String
  description  String
  rewardGuesses Int
  type         String

  completions TaskCompletion[]

  @@schema("crack_the_safe")
}

model TaskCompletion {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  claimedDate String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId, claimedDate])
  @@schema("crack_the_safe")
}

model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  type      String   // "prize_claim", "buy_guesses", "reward", "transfer"
  txHash    String?  // On-chain transaction hash (null for off-chain)
  vaultId   String?  // Related vault (for prize claims)
  metadata  String?  // JSON string for extra context
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@schema("crack_the_safe")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // "guess", "task_claim", "login", "prize_claim", "vault_rotate", "admin_action"
  details   String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@schema("crack_the_safe")
}
