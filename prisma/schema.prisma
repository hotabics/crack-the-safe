datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["crack_the_safe"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

model User {
  id             String   @id @default(cuid())
  displayName    String
  walletAddress  String?  @unique
  lastLoginDate  String?
  streakDays     Int      @default(0)
  createdAt      DateTime @default(now())

  guesses         Guess[]
  ledgerEntries   GuessLedger[]
  taskCompletions TaskCompletion[]
  crackedVaults   Vault[]          @relation("CrackedBy")

  @@schema("crack_the_safe")
}

model Vault {
  id        String   @id @default(cuid())
  codeLength Int      @default(4)
  codeHash  String
  startsAt  DateTime @default(now())
  expiresAt DateTime

  isCracked     Boolean  @default(false)
  crackedByUserId String?
  crackedAt     DateTime?
  crackedBy     User?    @relation("CrackedBy", fields: [crackedByUserId], references: [id])

  guesses Guess[]

  @@schema("crack_the_safe")
}

model Guess {
  id               String   @id @default(cuid())
  vaultId          String
  userId           String
  guess            String
  correctPositions Int
  correctDigits    Int
  feedback         String
  createdAt        DateTime @default(now())

  vault Vault @relation(fields: [vaultId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([vaultId, createdAt])
  @@index([userId, vaultId])
  @@schema("crack_the_safe")
}

model GuessLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  taskId    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@schema("crack_the_safe")
}

model Task {
  id           String @id
  name         String
  description  String
  rewardGuesses Int
  type         String

  completions TaskCompletion[]

  @@schema("crack_the_safe")
}

model TaskCompletion {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  claimedDate String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId, claimedDate])
  @@schema("crack_the_safe")
}
